# =============================================================================
# PeerTutor — Production Environment Variables
#
# Copy this file to .env.production and fill in your real values.
# .env.production is in .gitignore — it NEVER gets committed.
#
# Usage: bash scripts/deploy.sh
# =============================================================================

# ── AWS ───────────────────────────────────────────────────────────────────────
# The S3 bucket name created in AWS for the frontend static files
S3_BUCKET=schoolpeertutor-frontend-prod

# The CloudFront distribution ID (found in AWS Console → CloudFront)
CLOUDFRONT_DISTRIBUTION_ID=EXXXXXXXXXXXXXXXXX

# The AWS CLI profile to use for deploys (set up via: aws configure --profile schoolpeertutor)
AWS_PROFILE=schoolpeertutor

# ── Firebase Project ──────────────────────────────────────────────────────────
# Found in Firebase Console → Project Settings → General
FIREBASE_PROJECT_ID=peertutor-prod
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=peertutor-prod.firebaseapp.com
FIREBASE_STORAGE_BUCKET=peertutor-prod.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ── Firebase Functions Secrets (set once via firebase CLI, not re-injected on deploy) ──
# Run these once from your terminal — Firebase stores them securely in Secret Manager:
#
#   cd backend
#   firebase functions:secrets:set SENDGRID_API_KEY
#   firebase functions:secrets:set ANTHROPIC_API_KEY
#   firebase functions:secrets:set GOOGLE_CALENDAR_PRIVATE_KEY
#   firebase functions:secrets:set GOOGLE_CALENDAR_CLIENT_EMAIL
#   firebase functions:secrets:set SUPER_ADMIN_EMAIL
#
# You do NOT need to put those values in this file.
