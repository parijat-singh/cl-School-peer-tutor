# ─────────────────────────────────────────────────────────────────
# PeerTutor — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to source control
# ─────────────────────────────────────────────────────────────────

# ── Firebase Project Config ────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-web-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef

# ── Google Calendar API (Service Account) ─────────────────────
# Create a service account in GCP Console with Calendar API access
GOOGLE_CALENDAR_CLIENT_EMAIL=service-account@your-project.iam.gserviceaccount.com
GOOGLE_CALENDAR_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
# The calendar ID to create events on (use primary@group.calendar.google.com for shared)
GOOGLE_CALENDAR_ID=primary

# ── SendGrid ──────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@peertutor.app
SENDGRID_FROM_NAME=PeerTutor

# ── SendGrid Template IDs ──────────────────────────────────────
SENDGRID_TEMPLATE_BOOKING_CONFIRMATION=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_CANCELLATION=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_REMINDER=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_RATING_PROMPT=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_WELCOME=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Anthropic (Claude AI Recommendation Engine) ──────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ── App Config ────────────────────────────────────────────────
DOMAIN=peertutor.app
NODE_ENV=development

# ── Super Admin (for school approval) ─────────────────────────
SUPER_ADMIN_EMAIL=admin@peertutor.app
