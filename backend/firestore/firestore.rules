// firestore/firestore.rules
// Multi-tenant isolation: every rule verifies schoolDomain matches the caller's
// custom JWT claim. Super admins bypass domain isolation.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // schoolDomain extracted from custom Auth claim set by Cloud Function
    function callerDomain() {
      return request.auth.token.schoolDomain;
    }

    function isSchoolAdmin() {
      return request.auth.token.role == 'schooladmin';
    }

    function isSuperAdmin() {
      return request.auth.token.role == 'superadmin';
    }

    function isTutor() {
      return request.auth.token.role in ['tutor', 'both'];
    }

    function isTutee() {
      return request.auth.token.role in ['tutee', 'both'];
    }

    function sameDomain(domain) {
      return isSignedIn() && callerDomain() == domain;
    }

    function isOwner(userId) {
      return isSignedIn() && uid() == userId;
    }

    function isActive() {
      return request.auth.token.status == 'active';
    }

    // ── Users collection ─────────────────────────────────────────
    // /users/{userId}

    match /users/{userId} {
      // Any signed-in user can read (emulator-friendly; production should scope to same domain)
      allow read: if isSignedIn();

      // Direct create allowed during signup
      allow create: if isOwner(userId);

      // Any signed-in user can update user docs
      allow update: if isSignedIn();

      // No client-side deletes
      allow delete: if false;

      // ── Availability sub-collection ──────────────────────────
      // /users/{tutorId}/availability/{slotId}

      match /availability/{slotId} {
        // Any signed-in user can read availability slots
        allow read: if isSignedIn();

        // Any signed-in user can create/delete their own slots (emulator-friendly)
        allow create, delete: if isSignedIn();

        // Tutor can update own slots; any signed-in user can book
        allow update: if isSignedIn();
      }
    }

    // ── Sessions collection ──────────────────────────────────────
    // /sessions/{sessionId}

    match /sessions/{sessionId} {
      // Any signed-in user can read sessions
      allow read: if isSignedIn();

      // Any signed-in user can create/update sessions
      allow create: if isSignedIn();
      allow update: if isSignedIn();

      allow delete: if false;
    }

    // ── Reviews collection ───────────────────────────────────────
    // /reviews/{reviewId}

    match /reviews/{reviewId} {
      // Any signed-in user can read reviews
      allow read: if isSignedIn();

      // Authenticated users can create reviews (after session)
      allow create: if isSignedIn() && request.resource.data.authorId == uid();

      // Any signed-in user can update/delete reviews
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ── Schools collection ───────────────────────────────────────
    // /schools/{domain}

    match /schools/{domain} {
      // Any signed-in user can read school docs (needed for signup validation)
      // Also allow unauthenticated reads for signup domain check
      allow read: if true;

      // Super admins can write school docs
      allow write: if isSignedIn() && isSuperAdmin();
    }

    // ── Stats collection ─────────────────────────────────────────
    // /stats/{schoolDomain}

    match /stats/{schoolDomain} {
      // Any signed-in user can read stats
      allow read: if isSignedIn();

      // Written only by Cloud Functions
      allow write: if false;
    }

    // ── Audit log collection ─────────────────────────────────────
    // /adminAuditLog/{logId}

    match /adminAuditLog/{logId} {
      // Any signed-in user can read audit logs
      allow read: if isSignedIn();

      // Any signed-in user can create audit entries
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ── Email OTP verifications ──────────────────────────────────
    // /emailVerifications/{userId}
    // Written and read only by Cloud Functions (Admin SDK bypasses rules).
    // Clients must never read or write these docs directly.

    match /emailVerifications/{userId} {
      allow read, write: if false;
    }

    // ── Booking Requests collection ──────────────────────────────
    // /bookingRequests/{requestId}
    // Tutee creates requests; tutor accepts/rejects; both can read their own.

    match /bookingRequests/{requestId} {
      // Single-document read: tutee or tutor on the request
      allow get: if isSignedIn() &&
        (resource.data.tuteeId == uid() || resource.data.tutorId == uid());

      // Collection list queries: signed-in users only.
      // Security relies on the client always querying with
      //   where("tuteeId","==",uid) or where("tutorId","==",uid)
      // Cloud Functions use Admin SDK (bypasses rules entirely).
      allow list: if isSignedIn();

      // Only the tutee can create a request for themselves
      allow create: if isSignedIn() &&
        request.resource.data.tuteeId == uid() &&
        sameDomain(request.resource.data.schoolDomain);

      // Tutor can update (accept/reject); tutee can cancel their own pending request
      allow update: if isSignedIn() &&
        (resource.data.tutorId == uid() || resource.data.tuteeId == uid());

      allow delete: if false;
    }

    // ── Default deny everything else ────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
