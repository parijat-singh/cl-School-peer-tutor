// firestore/firestore.rules
// Multi-tenant isolation: every rule verifies schoolDomain matches the caller's
// custom JWT claim. Super admins bypass domain isolation.
//
// Data writes for sessions, reviews, bookings, audit log, and stats are handled
// exclusively by Cloud Functions (Admin SDK bypasses rules). Client-side writes
// are only allowed where explicitly needed (availability slots, user profile,
// school profile, review flagging).

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // schoolDomain extracted from custom Auth claim set by Cloud Function
    function callerDomain() {
      return request.auth.token.schoolDomain;
    }

    function isSchoolAdmin() {
      return request.auth.token.role == 'schooladmin';
    }

    function isSuperAdmin() {
      return request.auth.token.role == 'superadmin';
    }

    function isTutor() {
      return request.auth.token.role in ['tutor', 'both'];
    }

    function isTutee() {
      return request.auth.token.role in ['tutee', 'both'];
    }

    function sameDomain(domain) {
      return isSignedIn() && callerDomain() == domain;
    }

    function isOwner(userId) {
      return isSignedIn() && uid() == userId;
    }

    function isActive() {
      return request.auth.token.status == 'active';
    }

    // ── Users collection ─────────────────────────────────────────
    // /users/{userId}
    //
    // get:  own doc, same-domain, or superadmin
    // list: query must filter by schoolDomain (tutor search) or caller is superadmin
    // create: owner only (signup)
    // update: owner, same-domain school admin, or superadmin
    // delete: never (Cloud Functions handle deactivation, not deletion)

    match /users/{userId} {
      allow get: if isSignedIn() && (
        isOwner(userId) ||
        sameDomain(resource.data.schoolDomain) ||
        isSuperAdmin()
      );

      allow list: if isSignedIn() && (
        sameDomain(resource.data.schoolDomain) ||
        isSuperAdmin()
      );

      // Direct create allowed during signup
      allow create: if isOwner(userId);

      // Owner can update own profile; school admin can update same-domain users
      allow update: if isSignedIn() && (
        isOwner(userId) ||
        (isSchoolAdmin() && sameDomain(resource.data.schoolDomain)) ||
        isSuperAdmin()
      );

      // No client-side deletes
      allow delete: if false;

      // ── Availability sub-collection ──────────────────────────
      // /users/{tutorId}/availability/{slotId}
      //
      // read:   same-domain users (tutees browse tutor availability)
      // create: tutor creates own slots
      // update: owner (edit slot) or same-domain user (booking writes via CF,
      //         but some client-side updates like cancelRecurringDate)
      // delete: owner only

      match /availability/{slotId} {
        allow read: if isSignedIn() && (
          isOwner(userId) ||
          sameDomain(resource.data.schoolDomain) ||
          isSuperAdmin()
        );

        // Only the tutor (owner of parent user doc) can create slots
        allow create: if isOwner(userId) && isTutor();

        // Owner can edit own slots; same-domain needed for booking updates
        allow update: if isSignedIn() && (
          isOwner(userId) ||
          sameDomain(resource.data.schoolDomain)
        );

        // Only the slot owner can delete
        allow delete: if isOwner(userId);
      }
    }

    // ── Sessions collection ──────────────────────────────────────
    // /sessions/{sessionId}
    //
    // get:  participant (tutorId or tuteeId), same-domain admin, or superadmin
    // list: query must filter by tutorId==uid, tuteeId==uid, or schoolDomain
    // create/update: Cloud Functions only (Admin SDK bypasses rules)
    // delete: never

    match /sessions/{sessionId} {
      allow get: if isSignedIn() && (
        resource.data.tutorId == uid() ||
        resource.data.tuteeId == uid() ||
        (isSchoolAdmin() && sameDomain(resource.data.schoolDomain)) ||
        isSuperAdmin()
      );

      allow list: if isSignedIn() && (
        resource.data.tutorId == uid() ||
        resource.data.tuteeId == uid() ||
        sameDomain(resource.data.schoolDomain) ||
        isSuperAdmin()
      );

      // Sessions are created and updated exclusively by Cloud Functions
      allow create, update: if false;
      allow delete: if false;
    }

    // ── Reviews collection ───────────────────────────────────────
    // /reviews/{reviewId}
    //
    // read:   same-domain users or superadmin
    // update: same-domain users can flag reviews (flagged, flaggedBy fields)
    // create/delete: Cloud Functions only

    match /reviews/{reviewId} {
      allow get: if isSignedIn() && (
        sameDomain(resource.data.schoolDomain) ||
        isSuperAdmin()
      );

      allow list: if isSignedIn() && (
        sameDomain(resource.data.schoolDomain) ||
        isSuperAdmin()
      );

      // Same-domain users can only flag reviews (flagged + flaggedBy fields)
      allow update: if isSignedIn() &&
        sameDomain(resource.data.schoolDomain) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["flagged", "flaggedBy"]);

      // Reviews are created and deleted by Cloud Functions
      allow create, delete: if false;
    }

    // ── Schools collection ───────────────────────────────────────
    // /schools/{domain}
    //
    // read:  public (needed for signup domain validation before auth)
    // write: superadmin or school admin of that domain

    match /schools/{domain} {
      allow read: if true;

      allow write: if isSignedIn() && (
        isSuperAdmin() ||
        (isSchoolAdmin() && sameDomain(domain))
      );
    }

    // ── Stats collection ─────────────────────────────────────────
    // /stats/{schoolDomain}
    //
    // read:  same-domain users or superadmin
    // write: Cloud Functions only

    match /stats/{schoolDomain} {
      allow read: if isSignedIn() && (
        sameDomain(schoolDomain) ||
        isSuperAdmin()
      );

      // Written only by Cloud Functions
      allow write: if false;
    }

    // ── Audit log collection ─────────────────────────────────────
    // /adminAuditLog/{logId}
    //
    // read:  school admins (own domain) or superadmin
    // write: Cloud Functions only

    match /adminAuditLog/{logId} {
      allow read: if isSignedIn() && (
        isSchoolAdmin() ||
        isSuperAdmin()
      );

      // Audit entries are written exclusively by Cloud Functions
      allow create, update, delete: if false;
    }

    // ── Email OTP verifications ──────────────────────────────────
    // /emailVerifications/{userId}
    // Written and read only by Cloud Functions (Admin SDK bypasses rules).
    // Clients must never read or write these docs directly.

    match /emailVerifications/{userId} {
      allow read, write: if false;
    }

    // ── Booking Requests collection ──────────────────────────────
    // /bookingRequests/{requestId}
    //
    // get:    tutee or tutor on the request, same-domain admin, or superadmin
    // list:   query must filter by tuteeId==uid, tutorId==uid, or schoolDomain
    // create: tutee creates requests in own domain
    // update: tutor (accept/reject) or tutee (cancel own pending request)
    // delete: never

    match /bookingRequests/{requestId} {
      allow get: if isSignedIn() && (
        resource.data.tuteeId == uid() ||
        resource.data.tutorId == uid() ||
        (isSchoolAdmin() && sameDomain(resource.data.schoolDomain)) ||
        isSuperAdmin()
      );

      allow list: if isSignedIn() && (
        resource.data.tuteeId == uid() ||
        resource.data.tutorId == uid() ||
        sameDomain(resource.data.schoolDomain) ||
        isSuperAdmin()
      );

      // Only the tutee can create a request for themselves, in their own domain
      allow create: if isSignedIn() &&
        request.resource.data.tuteeId == uid() &&
        sameDomain(request.resource.data.schoolDomain);

      // Tutor can update (accept/reject); tutee can cancel their own pending request
      allow update: if isSignedIn() && (
        resource.data.tutorId == uid() ||
        resource.data.tuteeId == uid()
      );

      allow delete: if false;
    }

    // ── Default deny everything else ────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
