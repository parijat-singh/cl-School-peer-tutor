# ─────────────────────────────────────────────────────────────────
# PeerTutor — Environment Variables
# ─────────────────────────────────────────────────────────────────
#
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values below
#   3. NEVER commit .env to source control (it's in .gitignore)
# ─────────────────────────────────────────────────────────────────

# ── AWS Cognito (Auth) ────────────────────────────────────────
# From: terraform output (after running terraform apply in infra/terraform/)
# Frontend reads VITE_* vars at build time; backend reads the rest at runtime.
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_AWS_REGION=us-east-1

# ── API Gateway ──────────────────────────────────────────────
# From: terraform output api_gateway_url
VITE_API_URL=

# ── SMTP (Email) ────────────────────────────────────────────────
# Outlook personal accounts: smtp-mail.outlook.com port 587
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USER=your-email@outlook.com
SMTP_PASS=your-password-or-app-password
SMTP_FROM_NAME=PeerTutor
SMTP_FROM_EMAIL=your-email@outlook.com

# ── Google Calendar API (Service Account) ────────────────────────
GOOGLE_CALENDAR_CLIENT_EMAIL=
GOOGLE_CALENDAR_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=primary

# ── Anthropic (Claude AI Recommendation Engine) ─────────────────
ANTHROPIC_API_KEY=

# ── Super Admin ─────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@yourdomain.com

# ── Sentry (Error Tracking) ────────────────────────────────────
VITE_SENTRY_DSN=
SENTRY_DSN=

# ── App Config ──────────────────────────────────────────────────
DOMAIN=yourdomain.com
NODE_ENV=development
