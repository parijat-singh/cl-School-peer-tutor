rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // School logos — only admins of that school can write
    match /schools/{domain}/logo {
      allow read:  if request.auth != null && request.auth.token.schoolDomain == domain;
      allow write: if request.auth != null
                   && request.auth.token.role == 'admin'
                   && request.auth.token.schoolDomain == domain
                   && request.resource.size < 500 * 1024  // 500KB max
                   && request.resource.contentType.matches('image/.*');
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
