# =============================================================================
# PeerTutor — Production reference (do not commit real .env.production)
#
# Production config is driven by GitHub Actions secrets → CD writes
# backend/functions/.env via scripts/write-functions-deploy-env.mjs
# =============================================================================

# ── GitHub Actions secrets (CD) — backend Cloud Functions ───────────────────
# SENTRY_DSN
# SENTRY_RELEASE            (auto: commit SHA)
# SMTP_HOST                 (optional; default smtp.resend.com)
# SMTP_PORT
# SMTP_USER
# SMTP_PASS
# SMTP_FROM_EMAIL
# SMTP_FROM_NAME
# SUPER_ADMIN_EMAIL
# GOOGLE_CALENDAR_CLIENT_EMAIL
# GOOGLE_CALENDAR_PRIVATE_KEY   (paste full PEM; multiline OK)
# GOOGLE_CALENDAR_ID            (optional)
# ANTHROPIC_API_KEY             (optional)
#
# Frontend build (same repo secrets):
# VITE_RECAPTCHA_SITE_KEY   (reCAPTCHA v3 — Firebase App Check; optional until enforced)
# VITE_SENTRY_DSN           (optional)

# ── AWS (Terraform outputs → GitHub) ────────────────────────────────────────
# S3_BUCKET, CLOUDFRONT_DISTRIBUTION_ID, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION

# ── Firebase / frontend build ───────────────────────────────────────────────
# FIREBASE_PROJECT_ID, FIREBASE_TOKEN, FIREBASE_API_KEY, ...

# ── Runbooks ────────────────────────────────────────────────────────────────
# docs/runbooks/token-and-key-rotation.md
# docs/runbooks/firestore-pitr-and-backups.md
# docs/runbooks/app-check-and-waf.md
