# ─────────────────────────────────────────────────────────────────
# PeerTutor — Environment Variables
# ─────────────────────────────────────────────────────────────────
#
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values below
#   3. NEVER commit .env to source control (it's in .gitignore)
#
# For local development with emulators, "fake-*" placeholder
# values work fine — the emulators don't validate them.
# ─────────────────────────────────────────────────────────────────

# ── Firebase Project Config ──────────────────────────────────────
# Get these from: Firebase Console → Project Settings → General
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── SMTP (Email) ────────────────────────────────────────────────
# Outlook personal accounts: smtp-mail.outlook.com port 587
# If 2-factor auth is enabled, generate an App Password at:
#   account.microsoft.com/security → Advanced security → App passwords
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USER=your-email@outlook.com
SMTP_PASS=your-password-or-app-password
SMTP_FROM_NAME=PeerTutor
SMTP_FROM_EMAIL=your-email@outlook.com

# ── Google Calendar API (Service Account) ────────────────────────
# Create a service account in GCP Console with Calendar API access
GOOGLE_CALENDAR_CLIENT_EMAIL=
GOOGLE_CALENDAR_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=primary

# ── Anthropic (Claude AI Recommendation Engine) ─────────────────
# Get your API key from: https://console.anthropic.com/settings/keys
# Leave blank to use fallback rating-based sorting (no AI features)
ANTHROPIC_API_KEY=

# ── Super Admin ─────────────────────────────────────────────────
# Email that receives school registration approval requests
SUPER_ADMIN_EMAIL=admin@yourdomain.com

# ── Sentry (Error Tracking) ────────────────────────────────────
# Create a project at https://sentry.io → Settings → Projects
# Frontend DSN (React): create a Browser JavaScript project
VITE_SENTRY_DSN=
# Backend DSN (Cloud Functions): create a Node.js project
SENTRY_DSN=

# ── App Config ──────────────────────────────────────────────────
DOMAIN=yourdomain.com
NODE_ENV=development
