# ─────────────────────────────────────────────────────────────────
# PeerTutor — Environment Variables
# ─────────────────────────────────────────────────────────────────
#
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values below
#   3. NEVER commit .env to source control (it's in .gitignore)
#
# For local development with emulators, "fake-*" placeholder
# values work fine — the emulators don't validate them.
# ─────────────────────────────────────────────────────────────────

# ── Firebase Project Config ──────────────────────────────────────
# Get these from: Firebase Console → Project Settings → General
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── SendGrid (Email) ────────────────────────────────────────────
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=PeerTutor

# ── SendGrid Dynamic Template IDs ───────────────────────────────
# Create templates at: https://mc.sendgrid.com/dynamic-templates
SENDGRID_TEMPLATE_BOOKING_CONFIRMATION=
SENDGRID_TEMPLATE_CANCELLATION=
SENDGRID_TEMPLATE_REMINDER=
SENDGRID_TEMPLATE_RATING_PROMPT=
SENDGRID_TEMPLATE_WELCOME=

# ── Google Calendar API (Service Account) ────────────────────────
# Create a service account in GCP Console with Calendar API access
GOOGLE_CALENDAR_CLIENT_EMAIL=
GOOGLE_CALENDAR_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=primary

# ── Anthropic (Claude AI Recommendation Engine) ─────────────────
# Get your API key from: https://console.anthropic.com/settings/keys
# Leave blank to use fallback rating-based sorting (no AI features)
ANTHROPIC_API_KEY=

# ── Super Admin ─────────────────────────────────────────────────
# Email that receives school registration approval requests
SUPER_ADMIN_EMAIL=admin@yourdomain.com

# ── App Config ──────────────────────────────────────────────────
DOMAIN=yourdomain.com
NODE_ENV=development
